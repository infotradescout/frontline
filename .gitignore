# ============================================================================
# Frontline — .gitignore
# Unreal Engine + Windows + IDE artifacts
# ============================================================================

# --- Unreal generated folders ---
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/
.vs/
.vscode/

# --- Unreal generated project files ---
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.sln.docstates

# --- Unreal generated code project files (regenerated from .uproject) ---
*.xcodeproj
*.xcworkspace

# --- Build outputs (top-level) ---
Builds/Output/
Builds/Cooked/
Builds/Staged/
Builds/Archive/

# --- OS junk ---
Thumbs.db
desktop.ini
.DS_Store

# --- Temporary / local ---
*.tmp
*.log
*.bak

# --- Keep .gitkeep markers in otherwise-empty tracked folders ---
!**/.gitkeep
